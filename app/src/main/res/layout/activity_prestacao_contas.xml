<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F0FF"
    tools:context=".PrestacaoContasActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarPrestacao"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimary"
        android:minHeight="?attr/actionBarSize"
        android:theme="?attr/actionBarTheme"
        app:title="Prestação de Contas"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Cards de resumo -->
    <LinearLayout
        android:id="@+id/layoutResumo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_margin="12dp"
        app:layout_constraintTop_toBottomOf="@id/toolbarPrestacao"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="8dp"
            android:layout_marginEnd="4dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Recebido"
                android:textSize="12sp"
                android:gravity="center"
                android:textColor="#555555" />

            <TextView
                android:id="@+id/txtTotalRecebido"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R$ 5.000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#000000" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="8dp"
            android:layout_marginEnd="4dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Gasto"
                android:textSize="12sp"
                android:gravity="center"
                android:textColor="#555555" />

            <TextView
                android:id="@+id/txtTotalGasto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R$ 3.200"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#000000" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="8dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Saldo Atual"
                android:textSize="12sp"
                android:gravity="center"
                android:textColor="#555555" />

            <TextView
                android:id="@+id/txtSaldoAtual"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R$ 1.800"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#388E3C" />
        </LinearLayout>

    </LinearLayout>

    <!-- Lista de lançamentos -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerPrestacao"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/layoutResumo"
        app:layout_constraintBottom_toTopOf="@id/btnAdicionarLancamento"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnAdicionarLancamento"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Adicionar lançamento"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>