<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F0FF"
    tools:context=".MudancaActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarMudanca"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimary"
        android:minHeight="?attr/actionBarSize"
        android:theme="?attr/actionBarTheme"
        app:title="Mudança"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/etNomeResponsavel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Nome do responsável"
        android:inputType="textPersonName"
        android:gravity="center"
        android:background="@android:drawable/edit_text"
        android:padding="12dp"
        android:layout_marginTop="32dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toBottomOf="@id/toolbarMudanca"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/etNumeroApartamento"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Número do apartamento"
        android:inputType="number"
        android:gravity="center"
        android:background="@android:drawable/edit_text"
        android:padding="12dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toBottomOf="@id/etNomeResponsavel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/etDataMudanca"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Data da mudança (dd/mm/aaaa)"
        android:inputType="datetime"
        android:gravity="center"
        android:background="@android:drawable/edit_text"
        android:padding="12dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toBottomOf="@id/etNumeroApartamento"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/etTipoMudanca"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Tipo (Entrada / Saída)"
        android:inputType="text"
        android:gravity="center"
        android:background="@android:drawable/edit_text"
        android:padding="12dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toBottomOf="@id/etDataMudanca"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnCadastrarMudanca"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Cadastrar Mudança"
        android:layout_marginTop="24dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toBottomOf="@id/etTipoMudanca"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvMensagemMudanca"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cadastro realizado com sucesso"
        android:textColor="#FFFFFF"
        android:background="#222222"
        android:padding="12dp"
        android:visibility="gone"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/btnCadastrarMudanca"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>